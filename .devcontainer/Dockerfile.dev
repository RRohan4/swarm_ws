FROM osrf/ros:jazzy-desktop

# Add Docker's official apt repo for docker-ce-cli + compose plugin
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
         -o /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
         https://download.docker.com/linux/ubuntu \
         $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
         > /etc/apt/sources.list.d/docker.list \
    && rm -rf /var/lib/apt/lists/*

# Dev tools: colcon, pip, Docker CLI + Compose plugin, locale
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-colcon-common-extensions \
    python3-pip \
    docker-ce-cli \
    docker-buildx-plugin \
    docker-compose-plugin \
    locales \
    && locale-gen en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# Disable the secretservice credential helper
RUN mkdir -p /root/.docker \
    && echo '{"credsStore":""}' > /root/.docker/config.json

# Node.js (for Prettier formatting)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install prettier + xml plugin at a fixed path so pre-commit hooks work
# independently of whether npm install has been run in the workspace yet.
COPY package.json package-lock.json /opt/prettier/
RUN cd /opt/prettier && npm ci
ENV PATH="/opt/prettier/node_modules/.bin:${PATH}"
# NODE_PATH lets prettier resolve "@prettier/plugin-xml" from the baked-in location
ENV NODE_PATH="/opt/prettier/node_modules"

# Python linting / type-checking / pre-commit
RUN pip3 install --no-cache-dir --break-system-packages ruff mypy pre-commit

# Auto-source ROS in every shell
RUN echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc
